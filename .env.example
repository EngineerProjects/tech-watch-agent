# Core app
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/techwatch
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5433/techwatch

# LLM Provider (supports: openrouter, ollama, zai, openai)
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=              # Empty = use provider default model
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Available LLM Providers:
# - openrouter : https://openrouter.ai/api/v1  (API key required, many models)
# - ollama    : http://localhost:11434/v1     (no API key, local models)
# - zai       : https://api.z.ai/v1          (API key required)
# - openai   : https://api.openai.com/v1     (API key required)

# Web Search & Scraping
TAVILY_API_KEY=         # From tavily.com (optional - enables deep research Tavily search)
SCRAPLING_FETCHER=basic  # basic, stealth, or dynamic (default: basic)
SCRAPLING_TIMEOUT=30    # Request timeout in seconds
SCRAPLING_MAX_CONTENT_LENGTH=50000  # Max chars to return per page

# Crawl4AI (optional - install with: pip install crawl4ai && crawl4ai-setup)
CRAWL4AI_FILTER=pruning  # none, pruning, or bm25
CRAWL4AI_THRESHOLD=0.48  # Filter threshold (0.0-1.0)
CRAWL4AI_TIMEOUT=30      # Request timeout in seconds
CRAWL4AI_MAX_CONTENT_LENGTH=50000
CRAWL4AI_HEADLESS=true   # Run browser in headless mode

# Content Extractor (unified tool with fallback chain)
CONTENT_EXTRACTOR_STRATEGY=markdown  # markdown (Crawl4AI→Scrapling), speed (Scrapling), reliability (Stealth)
CONTENT_EXTRACTOR_TIMEOUT=60
CONTENT_EXTRACTOR_MAX_LENGTH=50000

# Newsletter
NEWSLETTER_TITLE=Tech Watch Agent
NEWSLETTER_TOPICS=AI news,Machine Learning breakthroughs,Tech startups,OpenAI updates,Google AI developments,Tech industry trends
MAX_ARTICLES_PER_TOPIC=5
CRAWL_TIMEOUT_SECONDS=30

# Delivery
SENDER_EMAIL=
RECIPIENT_EMAILS=
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Scheduling
SCHEDULE_TIMES=08:00,18:00
TIMEZONE=Europe/Paris
