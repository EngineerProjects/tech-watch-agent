# Tech Watch Agent — bootstrap minimal
#
# This file is only for infrastructure/bootstrap values.
# Runtime providers, API keys, newsletter settings, search settings,
# and Gmail OAuth should be configured from Settings in the app and stored in DB.

# Core app
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# PostgreSQL / pgvector
POSTGRES_DB=techwatch
POSTGRES_USER=techwatch
POSTGRES_PASSWORD=techwatch
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://techwatch:techwatch@postgres:5432/techwatch
DATABASE_SYNC_URL=postgresql://techwatch:techwatch@postgres:5432/techwatch

# App exposure / admin
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ADMIN_API_TOKEN=change-me

# Secrets at rest
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# Optional first-boot LLM bootstrap
# Leave LLM_MODEL empty if you want the app to use the first Ollama model it detects.
# For the project Docker stack, use `make up-ollama` to preload local models automatically.
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=
LLM_API_KEY=

# Local non-Docker override example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/techwatch
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5433/techwatch
# LLM_BASE_URL=http://127.0.0.1:11434/v1
