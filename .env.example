# Core app
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM provider
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4.1-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Newsletter
NEWSLETTER_TITLE=Tech Watch Agent
NEWSLETTER_TOPICS=AI news,Machine Learning breakthroughs,Tech startups,OpenAI updates,Google AI developments,Tech industry trends
MAX_ARTICLES_PER_TOPIC=5
CRAWL_TIMEOUT_SECONDS=30

# Delivery
SENDER_EMAIL=
RECIPIENT_EMAILS=
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Scheduling
SCHEDULE_TIMES=08:00,18:00
TIMEZONE=Europe/Paris
