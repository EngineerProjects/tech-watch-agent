# Tech Watch Agent — Minimal Docker bootstrap
# Copy to .env if you need to override the compose defaults.
# Runtime providers, API keys, newsletter settings, search knobs, and Gmail OAuth
# should now be configured from Settings in the web UI and stored in DB.

# Infra bootstrap
POSTGRES_DB=techwatch
POSTGRES_USER=techwatch
POSTGRES_PASSWORD=techwatch
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://techwatch:techwatch@postgres:5432/techwatch
DATABASE_SYNC_URL=postgresql://techwatch:techwatch@postgres:5432/techwatch
REDIS_URL=redis://redis:6379

# App exposure / admin
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_TOKEN=change-me

# Secrets at rest
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# Optional bootstrap for a first local run before runtime overrides exist.
# The compose file already defaults to local project services for search,
# and to Ollama on the Docker host for LLM calls.
APP_ENV=development
LOG_LEVEL=INFO
