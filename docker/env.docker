# Tech Watch Agent - Docker Environment Template
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/techwatch
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/techwatch

# Redis
REDIS_URL=redis://redis:6379

# LLM Provider (openrouter, ollama, zai, openai)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_KEY=

# Newsletter Topics (comma-separated)
NEWSLETTER_TOPICS=AI news,Machine Learning,Tech startups

# Email Delivery (Gmail OAuth)
SENDER_EMAIL=your-email@gmail.com
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com

# Application Settings
LOG_LEVEL=INFO
DEBUG=false

# Newsletter Settings
MAX_ARTICLES=20
MIN_SOURCES=5
SEND_EMAIL=true